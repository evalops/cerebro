{
  "id": "aws-api-gateway-no-authorization",
  "name": "AWS API Gateway No Authorization",
  "description": "API Gateway endpoint has no authorization configured",
  "effect": "forbid",
  "resource": "aws::apigateway::method",
  "conditions": [
    "authorization_type == 'NONE'",
    "api_key_required != true"
  ],
  "severity": "high",
  "remediation": "Configure IAM, Cognito, or Lambda authorizer for the API Gateway method.",
  "tags": [
    "api",
    "apigateway",
    "authentication",
    "public-api"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "IDENTITY_RISK"
  ],
