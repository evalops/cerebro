{
  "id": "k8s-ingress-no-authentication",
  "name": "Kubernetes Ingress No Authentication",
  "description": "Kubernetes Ingress lacks authentication annotations",
  "effect": "forbid",
  "resource": "kubernetes::networking::ingress",
  "conditions": [
    "annotations not contains 'nginx.ingress.kubernetes.io/auth-url'",
    "annotations not contains 'nginx.ingress.kubernetes.io/auth-signin'",
    "annotations not contains 'traefik.ingress.kubernetes.io/router.middlewares'"
  ],
  "severity": "medium",
  "remediation": "Configure external authentication via ingress annotations or use a service mesh.",
  "tags": [
    "api",
    "kubernetes",
    "ingress",
    "authentication"
  ],
  "risk_categories": [
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-2",
        "IA-5"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "8.3",
        "8.4"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "6"
      ]
    }
  ]
}