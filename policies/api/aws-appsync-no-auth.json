{
  "id": "aws-appsync-no-authorization",
  "name": "AWS AppSync No Authorization",
  "description": "AppSync GraphQL API has no authorization configured",
  "effect": "forbid",
  "resource": "aws::appsync::graphql_api",
  "conditions": [
    "authentication_type == 'API_KEY'",
    "additional_authentication_providers.length == 0"
  ],
  "severity": "high",
  "remediation": "Configure Cognito, IAM, or OIDC authentication for the AppSync API.",
  "tags": [
    "api",
    "appsync",
    "graphql",
    "authentication"
  ],
  "risk_categories": [
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-2",
        "IA-5"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "8.3",
        "8.4"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "6"
      ]
    }
  ]
}