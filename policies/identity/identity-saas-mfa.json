{
  "id": "identity-saas-mfa-enforced",
  "name": "MFA Enforced on SaaS Applications",
  "description": "All users should have MFA enabled on critical SaaS applications including identity providers, email, and collaboration tools",
  "effect": "forbid",
  "resource": "identity_user_accounts",
  "conditions": [
    "mfa_enabled != true",
    "account_active == true",
    "is_human_user == true"
  ],
  "severity": "high",
  "remediation": "Enable MFA for the user account. Enforce MFA at the organization level if available",
  "remediation_steps": [
    "Identify users without MFA enrolled",
    "Send MFA enrollment reminders",
    "Set a deadline for MFA enrollment",
    "Block access for users who don't enroll by deadline",
    "Consider hardware security keys for high-privilege users"
  ],
  "tags": [
    "identity",
    "mfa",
    "authentication",
    "saas"
  ],
  "risk_categories": [
    "IDENTITY_RISK",
    "UNPROTECTED_PRINCIPAL"
  ],
  "frameworks": [
    {
      "name": "CIS Controls v8",
      "controls": ["6.3", "6.4"]
    },
    {
      "name": "SOC 2",
      "controls": ["CC6.1"]
    },
    {
      "name": "ISO 27001:2022",
      "controls": ["A.5.17", "A.8.5"]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": ["IA-2"]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": ["8.4.2"]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Credential Access",
      "technique": "T1110"
    },
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    }
  ]
}
