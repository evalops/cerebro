{
  "id": "gcp-compute-public-ssh",
  "name": "GCP Instance Public IP with SSH Exposed",
  "description": "GCP Compute instance has external IP with firewall allowing SSH from 0.0.0.0/0",
  "effect": "forbid",
  "resource": "gcp::compute::instance",
  "conditions": [
    "network_interfaces.access_configs != null",
    "firewall_rules.allowed.ports contains '22'",
    "firewall_rules.source_ranges contains '0.0.0.0/0'"
  ],
  "severity": "critical",
  "remediation": "Remove external IP or restrict firewall rules. Use IAP for TCP forwarding for secure access.",
  "tags": [
    "cis-gcp-3.6",
    "exposure",
    "compute",
    "network",
    "ssh"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13"
      ]
    }
  ],
  "mitre_attack": [
    {
