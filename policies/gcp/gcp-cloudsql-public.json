{
  "id": "gcp-cloudsql-no-public-ip",
  "name": "Cloud SQL Public IP",
  "description": "Cloud SQL instances should not have public IP addresses",
  "effect": "forbid",
  "resource": "gcp::sql::database_instance",
  "conditions": [
    "ip_addresses.type == 'PRIMARY'"
  ],
  "severity": "high",
  "remediation": "Configure Cloud SQL to use private IP only. Use Cloud SQL Proxy for secure connections.",
  "tags": [
    "cis-gcp-6.2",
    "cloudsql",
    "database",
    "network"
  ],
