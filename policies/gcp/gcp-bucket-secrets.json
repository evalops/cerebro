{
  "id": "gcp-bucket-secrets",
  "name": "GCS Bucket Contains Potential Credentials",
  "description": "Cloud Storage bucket objects contain potential secrets, API keys, or credentials",
  "effect": "forbid",
  "resource": "gcp::storage::object",
  "conditions": [
    "name MATCHES '.*\\.(pem|key|json|credentials|env|secret)$' OR name MATCHES '.*(service.?account|api.?key|private.?key).*'"
  ],
  "severity": "high",
  "remediation": "Move secrets to Secret Manager. Remove credential files from GCS. Enable object versioning and audit logging.",
  "tags": [
    "gcp",
    "storage",
    "secrets",
    "data-exposure"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7",
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4",
        "3.5",
        "8.6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}