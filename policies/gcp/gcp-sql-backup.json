    "cis-gcp-6.7",
    "cloudsql",
    "database",
    "backup"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "mitre_attack": [
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}