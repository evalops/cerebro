{
  "id": "gcp-sa-admin-privileges",
  "name": "GCP Service Account with Admin Privileges",
  "description": "Service account has been granted organization or project admin roles",
  "effect": "forbid",
  "resource": "gcp::iam::service_account",
  "conditions": [
    "iam_bindings ANY (role IN ('roles/owner', 'roles/editor', 'roles/resourcemanager.organizationAdmin', 'roles/resourcemanager.projectIamAdmin'))"
  ],
  "severity": "high",
  "remediation": "Remove admin roles from service accounts. Create custom roles with minimal required permissions. Use Workload Identity Federation where possible.",
  "tags": [
    "gcp",
    "iam",
    "service-account",
    "least-privilege",
    "cis-gcp-1.5"
  ],
  "risk_categories": [
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Persistence",
      "technique": "T1098"
    },
    {
      "tactic": "Privilege Escalation",
      "technique": "T1078"
    }
  ]
}