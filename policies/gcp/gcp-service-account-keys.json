{
  "id": "gcp-service-account-key-rotation",
  "name": "Service Account Key Rotation",
  "description": "Service account keys should be rotated within 90 days",
  "effect": "forbid",
  "resource": "gcp::iam::service_account_key",
  "conditions": [
    "key_type == 'USER_MANAGED'",
    "valid_after_time \u003c now() - 90d"
  ],
  "severity": "medium",
  "remediation": "Rotate service account keys every 90 days. Consider using workload identity instead of keys.",
  "tags": [
    "cis-gcp-1.7",
    "iam",
    "service-account",
    "key-rotation"
  ],
  "risk_categories": [
    "IDENTITY_RISK",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6",
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2",
        "3.5",
        "8.6"
      ]
    },
    {
