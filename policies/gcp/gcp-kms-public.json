{
  "id": "gcp-kms-public",
  "name": "KMS Key Publicly Accessible",
  "description": "Cloud KMS key grants access to allUsers or allAuthenticatedUsers",
  "effect": "forbid",
  "resource": "gcp::kms::crypto_key",
  "conditions": [
    "iam_policy.bindings ANY (members CONTAINS 'allUsers' OR members CONTAINS 'allAuthenticatedUsers')"
  ],
  "severity": "critical",
  "remediation": "Remove allUsers and allAuthenticatedUsers from KMS key IAM policy. Grant access to specific principals only.",
  "tags": [
    "gcp",
    "kms",
    "encryption",
    "public-access",
    "data-protection"
  ],
