{
  "id": "gcp-storage-uniform-bucket-access",
  "name": "GCP Storage Uniform Bucket Access",
  "description": "Cloud Storage buckets should use uniform bucket-level access",
  "effect": "forbid",
  "resource": "gcp::storage::bucket",
  "conditions": [
    "iam_configuration.uniform_bucket_level_access.enabled != true"
  ],
  "severity": "medium",
  "remediation": "Enable uniform bucket-level access to use IAM consistently for access control.",
