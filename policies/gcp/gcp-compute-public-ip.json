{
  "id": "gcp-compute-no-public-ip",
  "name": "Compute Instance Public IP",
  "description": "Compute instances should not have public IP addresses unless required",
  "effect": "forbid",
  "resource": "gcp::compute::instance",
  "conditions": [
    "network_interfaces.access_configs != null",
    "labels.allow_public_ip != 'true'"
  ],
  "severity": "high",
  "remediation": "Remove external IP addresses from compute instances. Use Cloud NAT for outbound internet access.",
  "tags": [
    "cis-gcp-4.9",
    "compute",
    "network",
    "public-ip"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "MISCONFIGURATION"
  ],
