{
  "id": "gcp-gke-default-sa",
  "name": "GKE Node Pool Using Default Service Account",
  "description": "GKE node pool is using the Compute Engine default service account instead of a dedicated service account",
  "effect": "forbid",
  "resource": "gcp::container::node_pool",
  "conditions": [
    "config.service_account == 'default' OR config.service_account ENDS_WITH '-compute@developer.gserviceaccount.com'"
  ],
  "severity": "medium",
  "remediation": "Create a dedicated service account with minimal permissions for the node pool. Update the node pool configuration.",
  "tags": [
    "gcp",
    "gke",
    "kubernetes",
    "least-privilege",
    "cis-gcp-7.17"
  ],
  "risk_categories": [
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Privilege Escalation",
      "technique": "T1078"
    }
  ]
}