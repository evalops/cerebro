{
  "id": "ai-model-third-party-access",
  "control_id": "wc-id-2274",
  "name": "3rd party access to AI model in bucket",
  "description": "A third party has access to AI model artifacts stored in a bucket",
  "effect": "forbid",
  "resource": "storage::bucket",
  "conditions": [
    "contains_ml_model == true",
    "iam_policy.principals ANY (is_third_party == true)"
  ],
  "severity": "high",
  "remediation": "Review and restrict third-party access to AI model artifacts. Implement proper model governance.",
  "tags": [
    "wiz",
    "ai",
    "third-party",
    "model-security"
  ],
