{
  "id": "log4shell-privileged",
  "control_id": "wc-id-613",
  "name": "VM/serverless with high privileges vulnerable to CVE-2021-44228 (Log4Shell)",
  "description": "A privileged resource is vulnerable to Log4Shell",
  "effect": "forbid",
  "resource": "compute::instance|serverless::function",
  "conditions": [
    "service_account.has_high_privilege == true OR attached_role.has_high_privilege == true",
    "vulnerabilities ANY (cve_id == 'CVE-2021-44228')"
  ],
  "severity": "critical",
  "remediation": "Patch Log4j immediately. Reduce privileges until patch is applied.",
  "tags": [
    "wiz",
    "compute",
    "vulnerability",
    "log4shell",
    "privileged"
  ],
