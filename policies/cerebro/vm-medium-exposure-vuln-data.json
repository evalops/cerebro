        "5",
        "6",
        "7"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}