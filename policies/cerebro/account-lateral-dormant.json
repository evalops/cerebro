{
  "id": "account-lateral-dormant",
  "control_id": "wc-id-990",
  "name": "Account with a lateral movement finding to admin is inactive for over 90 days",
  "description": "A dormant account has an attack path to admin privileges, posing a risk if the account is compromised",
  "effect": "forbid",
  "resource": "iam::user|iam::service_account",
  "conditions": [
    "last_activity_days_ago \u003e 90",
    "attack_paths ANY (target.is_admin == true)"
  ],
  "severity": "high",
  "remediation": "Disable or delete dormant accounts. Break the attack path to admin if the account must be retained.",
  "tags": [
    "wiz",
    "identity",
    "dormant",
    "lateral-movement",
    "admin"
  ],
