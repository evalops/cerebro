{
  "id": "openssl-vuln-internal",
  "control_id": "wc-id-997",
  "name": "Internal VM/serverless vulnerable to CVE-2022-3602 or CVE-2022-3786 (OpenSSL vulnerability)",
  "description": "An internal resource is vulnerable to OpenSSL buffer overflow vulnerabilities",
  "effect": "forbid",
  "resource": "compute::instance|serverless::function",
  "conditions": [
    "vulnerabilities ANY (cve_id IN ('CVE-2022-3602', 'CVE-2022-3786'))"
  ],
  "severity": "high",
  "remediation": "Update OpenSSL to version 3.0.7 or later.",
