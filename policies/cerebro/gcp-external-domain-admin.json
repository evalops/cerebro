{
  "id": "gcp-external-domain-admin",
  "control_id": "wc-id-1830",
  "name": "User account with non organizational domain (gmail) and high/admin access in GCP",
  "description": "A personal email account (non-organizational) has high or admin access to GCP resources",
  "effect": "forbid",
  "resource": "gcp::iam::member",
  "conditions": [
    "email MATCHES '.*@gmail.com$|.*@outlook.com$|.*@yahoo.com$|.*@hotmail.com$'",
    "has_high_privilege == true OR has_admin_role == true"
  ],
  "severity": "high",
  "remediation": "Replace personal accounts with organizational accounts. Remove high privileges from personal accounts immediately.",
  "tags": [
    "wiz",
    "gcp",
    "identity",
    "external-domain",
    "admin"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Privilege Escalation",
      "technique": "T1078"
    }
  ]
}