{
  "id": "user-privileged-unused-password",
  "control_id": "wc-id-1372",
  "name": "User account with high privileges and an unused password",
  "description": "A privileged user account has a password that has never been used, suggesting the account may be dormant",
  "effect": "forbid",
  "resource": "iam::user",
  "conditions": [
    "has_high_privilege == true",
    "password_last_used == null OR password_last_used_days_ago \u003e 365"
  ],
  "severity": "high",
  "remediation": "Review and disable unused privileged accounts. Implement regular access certification.",
  "tags": [
    "wiz",
    "identity",
    "dormant",
    "privileged",
    "unused-password"
  ],
  "risk_categories": [
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
