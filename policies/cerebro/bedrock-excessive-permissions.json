{
  "id": "bedrock-excessive-permissions",
  "control_id": "wc-id-2780",
  "name": "Bedrock AI Service Role with Excessive Permissions",
  "description": "An AWS Bedrock service role has excessive permissions beyond model invocation",
  "effect": "forbid",
  "resource": "aws::iam::role",
  "conditions": [
    "used_by_bedrock == true",
    "policy_document CONTAINS ('*') OR has_admin_actions == true"
  ],
  "severity": "high",
  "remediation": "Reduce Bedrock service role to minimum required permissions. Use specific model ARNs in policies.",
