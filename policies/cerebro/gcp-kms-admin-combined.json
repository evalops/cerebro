{
  "id": "gcp-kms-admin-combined",
  "control_id": "wc-id-624",
  "name": "User account with both 'Cloud KMS Admin' and 'Cloud CryptoKey Encrypter/Decrypter' roles assigned",
  "description": "A user can both manage KMS keys and use them for encryption, bypassing separation of duties",
  "effect": "forbid",
  "resource": "gcp::iam::member",
  "conditions": [
    "roles ANY (name == 'roles/cloudkms.admin')",
    "roles ANY (name IN ('roles/cloudkms.cryptoKeyEncrypterDecrypter', 'roles/cloudkms.cryptoKeyEncrypter', 'roles/cloudkms.cryptoKeyDecrypter'))"
  ],
  "severity": "high",
  "remediation": "Separate KMS administration from key usage. Apply separation of duties for cryptographic operations.",
  "tags": [
    "wiz",
    "gcp",
    "kms",
    "identity",
    "separation-of-duties"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "SC-12",
        "SC-13",
        "SC-28",
        "IA-5"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "4.2",
        "8.6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "3"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Persistence",
      "technique": "T1098"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}