{
  "id": "data-access-keys-unrotated",
  "control_id": "wc-id-2225",
  "name": "User/service account with access to sensitive data and active access keys unrotated in the past year",
  "description": "An account with access to sensitive data has access keys that have not been rotated in over a year",
  "effect": "forbid",
  "resource": "iam::user|iam::service_account",
  "conditions": [
    "has_sensitive_data_access == true",
    "access_keys ANY (status == 'Active' AND created_days_ago \u003e 365)"
  ],
  "severity": "high",
  "remediation": "Rotate access keys. Implement key rotation policy for accounts with data access.",
  "tags": [
    "wiz",
    "identity",
    "access-keys",
    "data-access",
    "rotation"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
