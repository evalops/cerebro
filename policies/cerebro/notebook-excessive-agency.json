{
  "id": "notebook-excessive-agency",
  "control_id": "wc-id-2273",
  "name": "Notebook with excessive agency",
  "description": "A notebook has excessive permissions that could lead to unintended resource access",
  "effect": "forbid",
  "resource": "ai::notebook",
  "conditions": [
    "execution_role.has_admin_role == true OR can_access_production_data == true"
  ],
  "severity": "high",
  "remediation": "Reduce notebook execution role permissions. Separate development and production access.",
  "tags": [
    "wiz",
    "ai",
    "notebook",
    "agency",
    "permissions"
  ],
