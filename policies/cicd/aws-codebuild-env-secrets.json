{
  "id": "aws-codebuild-plaintext-secrets",
  "name": "AWS CodeBuild Plaintext Secrets",
  "description": "CodeBuild project has secrets in plaintext environment variables",
  "effect": "forbid",
  "resource": "aws::codebuild::project",
  "conditions": [
    "environment.environment_variables contains { type: 'PLAINTEXT', name matches '(?i)(secret|password|token|key|api_key)' }"
  ],
  "severity": "critical",
  "remediation": "Use SECRETS_MANAGER or PARAMETER_STORE type for sensitive environment variables.",
  "tags": [
    "cicd",
    "codebuild",
    "secrets",
    "credentials"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Execution",
      "technique": "T1059"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}