{
  "id": "terraform-cloud-no-team-access-control",
  "name": "Terraform Cloud Workspace Without Team Access Control",
  "description": "Terraform Cloud workspace lacks team-based access control",
  "effect": "forbid",
  "resource": "terraform::workspace",
  "conditions": [
    "team_access == null || team_access.length == 0"
  ],
  "severity": "medium",
  "remediation": "Configure team access permissions for the Terraform Cloud workspace.",
  "tags": [
    "cicd",
    "terraform",
    "iac",
    "access-control"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ]
}