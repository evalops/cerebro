{
  "id": "aws-ec2-imdsv2-required",
  "name": "EC2 IMDSv2 Required",
  "description": "EC2 instances should require IMDSv2 to prevent SSRF attacks",
  "effect": "forbid",
  "resource": "aws::ec2::instance",
  "conditions": [
    "metadata_options_http_tokens != required"
  ],
  "severity": "high",
  "tags": [
    "cis-aws-5.6",
    "security",
    "ec2",
    "ssrf"
  ],
  "risk_categories": [
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "CIS AWS Foundations Benchmark v2.0",
      "controls": [
        "5.6"
      ]
    }
  ]
}