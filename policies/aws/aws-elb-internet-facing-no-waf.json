{
  "id": "aws-elb-internet-facing-no-waf",
  "name": "Internet-Facing ALB Without WAF",
  "description": "Application Load Balancer is internet-facing without AWS WAF protection",
  "effect": "forbid",
  "resource": "aws::elbv2::load_balancer",
  "conditions": [
    "scheme == 'internet-facing'",
    "type == 'application'",
    "waf_web_acl_arn == null"
  ],
  "severity": "high",
  "remediation": "Associate an AWS WAF WebACL with the Application Load Balancer to protect against common web exploits.",
  "tags": [
    "alb",
    "waf",
    "exposure",
    "network"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
