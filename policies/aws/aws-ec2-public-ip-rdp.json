{
  "id": "aws-ec2-public-ip-rdp",
  "name": "EC2 Public IP with RDP Exposed",
  "description": "EC2 instance has public IP with RDP port 3389 open to the internet (0.0.0.0/0)",
  "effect": "forbid",
  "resource": "aws::ec2::instance",
  "conditions": [
    "public_ip_address != null",
    "security_groups.ingress.from_port \u003c= 3389",
    "security_groups.ingress.to_port \u003e= 3389",
    "security_groups.ingress.cidr_blocks contains '0.0.0.0/0'"
  ],
  "severity": "critical",
  "remediation": "Remove public IP or restrict security group to specific IP ranges. Use AWS Systems Manager Session Manager for secure access.",
  "tags": [
    "cis-aws-5.3",
    "exposure",
    "ec2",
    "network",
    "rdp"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
