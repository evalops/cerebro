{
  "id": "aws-config-enabled-all-regions",
  "name": "AWS Config Enabled All Regions",
  "description": "AWS Config should be enabled in all regions to track resource configuration changes",
  "effect": "forbid",
  "resource": "aws::config::configuration_recorder",
  "conditions": [
    "recording != true"
  ],
  "severity": "medium",
  "remediation": "Enable AWS Config in all regions with recording enabled for all resource types.",
  "tags": [
    "cis-aws-3.5",
    "config",
    "monitoring",
    "compliance"
  ],
