{
  "id": "aws-rds-multi-az-enabled",
  "name": "RDS Multi-AZ Enabled",
  "description": "RDS instances should have Multi-AZ enabled for high availability",
  "effect": "forbid",
  "resource": "aws::rds::db_instance",
  "conditions": [
    "multi_az != true",
    "engine != 'aurora'"
  ],
  "severity": "medium",
  "remediation": "Enable Multi-AZ deployment for the RDS instance.",
  "tags": [
    "rds",
    "database",
    "availability",
    "disaster-recovery"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "mitre_attack": [
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}