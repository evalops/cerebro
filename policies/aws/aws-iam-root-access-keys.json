{
  "id": "aws-iam-root-no-access-keys",
  "name": "Root Account Access Keys",
  "description": "The root account should not have active access keys",
  "effect": "forbid",
  "resource": "aws::iam::credential_report",
  "conditions": [
    "user == '\u003croot_account\u003e'",
    "access_key_1_active == true OR access_key_2_active == true"
  ],
  "severity": "critical",
  "remediation": "Delete all access keys associated with the root account. Use IAM users or roles for programmatic access.",
  "tags": [
    "cis-aws-1.4",
    "iam",
    "root-account",
    "access-keys"
  ],
  "risk_categories": [
    "IDENTITY_RISK",
    "MISCONFIGURATION"
  ],
