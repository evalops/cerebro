{
  "id": "aws-rds-iam-authentication",
  "name": "RDS IAM Authentication",
  "description": "RDS instances should have IAM database authentication enabled",
  "effect": "forbid",
  "resource": "aws::rds::db_instance",
  "conditions": [
    "iam_database_authentication_enabled != true"
  ],
  "severity": "low",
  "remediation": "Enable IAM database authentication for centralized credential management.",
  "tags": [
    "rds",
    "database",
    "iam",
    "authentication"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "IDENTITY_RISK",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-2",
        "IA-5",
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "8.3",
        "8.4",
        "7.2"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "6",
        "5"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Persistence",
      "technique": "T1098"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}