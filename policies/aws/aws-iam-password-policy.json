{
  "id": "aws-iam-password-policy",
  "name": "IAM Password Policy Requirements",
  "description": "IAM password policy should enforce strong passwords with minimum length, complexity, and rotation requirements",
  "effect": "forbid",
  "resource": "aws::iam::account_password_policy",
  "conditions": [
    "minimum_password_length \u003c 14",
    "require_symbols != true",
    "require_numbers != true",
    "require_uppercase_characters != true",
    "require_lowercase_characters != true",
    "max_password_age \u003e 90"
  ],
  "severity": "medium",
  "remediation": "Update the IAM password policy to require minimum 14 characters, symbols, numbers, and uppercase/lowercase letters with 90-day rotation.",
  "tags": [
    "cis-aws-1.8",
    "cis-aws-1.9",
    "cis-aws-1.10",
    "iam",
    "authentication"
  ],
  "risk_categories": [
    "IDENTITY_RISK",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "CIS AWS Foundations Benchmark v2.0",
      "controls": [
        "1.8",
        "1.9",
        "1.10"
      ]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-2",
        "IA-5",
        "AC-2",
        "AC-6"
      ]
    },
    {
