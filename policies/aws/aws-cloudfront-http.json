{
  "id": "aws-cloudfront-http",
  "name": "CloudFront Distribution Allows HTTP",
  "description": "CloudFront distribution allows unencrypted HTTP traffic instead of requiring HTTPS",
  "effect": "forbid",
  "resource": "aws::cloudfront::distribution",
  "conditions": [
    "viewer_protocol_policy != 'https-only' AND viewer_protocol_policy != 'redirect-to-https'"
  ],
  "severity": "medium",
  "remediation": "Update the distribution's viewer protocol policy to 'redirect-to-https' or 'https-only'. Ensure a valid SSL certificate is configured.",
  "tags": [
    "aws",
    "cloudfront",
    "encryption",
    "transport-security"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "SC-12",
        "SC-13",
        "SC-28"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "4.2"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "3"
      ]
    }
  ]
}