{
  "id": "aws-rds-no-public-access",
  "name": "RDS No Public Access",
  "description": "RDS instances should not be publicly accessible",
  "effect": "forbid",
  "resource": "aws::rds::db_instance",
  "conditions": [
    "publicly_accessible == true"
  ],
