{
  "id": "aws-apigateway-public",
  "name": "API Gateway Publicly Accessible",
  "description": "API Gateway REST API is publicly accessible from the internet without authorization",
  "effect": "forbid",
  "resource": "aws::apigateway::rest_api",
  "conditions": [
    "endpoint_configuration.types CONTAINS 'EDGE' OR endpoint_configuration.types CONTAINS 'REGIONAL'",
    "web_acl_arn == null"
  ],
  "severity": "medium",
  "remediation": "Configure the API as private with VPC endpoint access. Use resource policies to restrict access. Enable authorization on all methods. Attach a WAF web ACL.",
  "tags": [
    "aws",
    "apigateway",
    "network-exposure",
    "cis-aws-2.6"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
