{
  "id": "aws-iam-user-unused-credentials",
  "name": "IAM User Unused Credentials",
  "description": "IAM user credentials (password or access keys) have not been used in 90+ days",
  "effect": "forbid",
  "resource": "aws::iam::credential_report",
  "conditions": [
    "password_last_used_days \u003e 90 OR access_key_1_last_used_days \u003e 90 OR access_key_2_last_used_days \u003e 90"
  ],
  "severity": "medium",
  "remediation": "Disable or delete unused IAM user credentials. Review if user still requires access.",
  "tags": [
    "cis-aws-1.12",
    "iam",
    "hygiene",
    "credentials"
  ],
  "risk_categories": [
    "IDENTITY_RISK"
  ],
