{
  "id": "aws-lambda-secrets-in-env-vars",
  "name": "Lambda Secrets in Environment Variables",
  "description": "Lambda function has potential secrets stored in plaintext environment variables",
  "effect": "forbid",
  "resource": "aws::lambda::function",
  "conditions": [
    "environment.variables matches '(?i)(password|passwd|secret|api_key|apikey|access_key|token|credential|private_key)'"
  ],
  "severity": "high",
  "remediation": "Use AWS Secrets Manager or Parameter Store to store sensitive values. Reference them at runtime.",
  "tags": [
    "secrets",
    "lambda",
    "credentials",
    "data-exposure"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7",
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4",
        "3.5",
        "8.6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Execution",
      "technique": "T1059"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}