{
  "id": "aws-sns-topic-encrypted",
  "name": "SNS Topic Encrypted",
  "description": "SNS topics should be encrypted with KMS",
  "effect": "forbid",
  "resource": "aws::sns::topic",
  "conditions": [
    "kms_master_key_id == null"
  ],
  "severity": "medium",
  "remediation": "Enable server-side encryption for the SNS topic using a KMS key.",
  "tags": [
    "sns",
    "encryption",
    "messaging"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "SC-12",
        "SC-13",
        "SC-28"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "4.2"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "3"
      ]
    }
  ]
}