{
  "id": "aws-security-group-restrict-ssh",
  "name": "Security Group SSH Restriction",
  "description": "Security groups should not allow unrestricted SSH access (0.0.0.0/0 on port 22)",
  "effect": "forbid",
  "resource": "aws::ec2::security_group",
  "conditions": [
    "ip_permissions.from_port \u003c= 22",
    "ip_permissions.to_port \u003e= 22",
    "ip_permissions.ip_ranges contains '0.0.0.0/0'"
  ],
  "severity": "high",
  "remediation": "Restrict SSH access to specific IP ranges or use AWS Systems Manager Session Manager for remote access.",
  "tags": [
    "cis-aws-5.2",
    "security-group",
    "network",
    "ssh",
    "remote-access"
  ],
  "risk_categories": [
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "CIS AWS Foundations Benchmark v2.0",
      "controls": [
        "5.2"
      ]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2"
      ]
    },
    {
