{
  "id": "aws-ecs-secrets-in-env-vars",
  "name": "ECS Task Secrets in Environment Variables",
  "description": "ECS task definition has potential secrets stored in plaintext environment variables",
  "effect": "forbid",
  "resource": "aws::ecs::task_definition",
  "conditions": [
    "container_definitions.environment.name matches '(?i)(password|passwd|secret|api_key|apikey|access_key|token|credential)'",
    "container_definitions.environment.value != null"
  ],
  "severity": "high",
  "remediation": "Use AWS Secrets Manager with ECS secrets integration or Parameter Store references.",
  "tags": [
    "secrets",
    "ecs",
    "credentials",
    "data-exposure"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7",
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4",
        "3.5",
        "8.6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}