{
  "id": "aws-secretsmanager-rotation-enabled",
  "name": "Secrets Manager Rotation Enabled",
  "description": "Secrets Manager secrets should have automatic rotation enabled",
  "effect": "forbid",
  "resource": "aws::secretsmanager::secret",
  "conditions": [
    "rotation_enabled != true"
  ],
  "severity": "medium",
  "remediation": "Enable automatic rotation for the secret with an appropriate rotation Lambda function.",
  "tags": [
    "secretsmanager",
    "secrets",
    "rotation",
    "credentials"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}