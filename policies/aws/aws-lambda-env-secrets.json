{
  "id": "aws-lambda-no-env-secrets",
  "name": "Lambda No Environment Secrets",
  "description": "Lambda functions should not have secrets in environment variables",
  "effect": "forbid",
  "resource": "aws::lambda::function",
  "conditions": [
    "environment.variables matches '(?i)(password|secret|api_key|apikey|token|credential)'"
  ],
  "severity": "high",
  "remediation": "Use AWS Secrets Manager or Parameter Store for sensitive values instead of environment variables.",
  "tags": [
    "lambda",
    "serverless",
    "secrets",
    "credentials"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Execution",
      "technique": "T1059"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}