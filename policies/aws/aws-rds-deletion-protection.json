{
  "id": "aws-rds-deletion-protection",
  "name": "RDS Deletion Protection",
  "description": "RDS instances should have deletion protection enabled",
  "effect": "forbid",
  "resource": "aws::rds::db_instance",
  "conditions": [
    "deletion_protection != true"
  ],
  "severity": "medium",
  "remediation": "Enable deletion protection to prevent accidental database deletion.",
  "tags": [
    "rds",
    "database",
    "data-protection"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "mitre_attack": [
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}