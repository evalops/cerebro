{
  "id": "aws-lambda-runtime-supported",
  "name": "Lambda Runtime Supported",
  "description": "Lambda functions should use supported runtimes",
  "effect": "forbid",
  "resource": "aws::lambda::function",
  "conditions": [
    "runtime in ['python2.7', 'python3.6', 'nodejs10.x', 'nodejs12.x', 'dotnetcore2.1', 'ruby2.5']"
  ],
  "severity": "medium",
  "remediation": "Upgrade Lambda function to a supported runtime version.",
  "tags": [
    "lambda",
    "serverless",
    "runtime",
    "deprecation"
  ],
  "risk_categories": [
    "MISCONFIGURATION"
  ],
  "mitre_attack": [
    {
      "tactic": "Execution",
      "technique": "T1059"
    }
  ]
}