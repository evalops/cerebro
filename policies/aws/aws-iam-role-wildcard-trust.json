{
  "id": "aws-iam-role-wildcard-trust",
  "name": "IAM Role Wildcard Trust Policy",
  "description": "IAM role trust policy allows assumption from any AWS account or principal",
  "effect": "forbid",
  "resource": "aws::iam::role",
  "conditions": [
    "assume_role_policy_document.Statement.Principal.AWS == '*'"
  ],
  "severity": "critical",
  "remediation": "Restrict trust policy to specific accounts, roles, or services with conditions.",
