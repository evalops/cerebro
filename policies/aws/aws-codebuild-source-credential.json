{
  "id": "aws-codebuild-source-credential",
  "name": "CodeBuild Source Credentials Stored Insecurely",
  "description": "CodeBuild project stores source credentials directly instead of using Secrets Manager or Parameter Store",
  "effect": "forbid",
  "resource": "aws::codebuild::source_credential",
  "conditions": [
    "auth_type == 'BASIC_AUTH'",
    "server_type IN ('GITHUB', 'GITHUB_ENTERPRISE', 'BITBUCKET', 'GITLAB')"
  ],
  "severity": "high",
  "remediation": "Use OAuth or personal access tokens stored in Secrets Manager. Configure CodeBuild to use credential references. Rotate any exposed credentials immediately.",
  "tags": [
    "aws",
    "codebuild",
    "secrets",
    "ci-cd",
    "cwe-522"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Execution",
      "technique": "T1059"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}