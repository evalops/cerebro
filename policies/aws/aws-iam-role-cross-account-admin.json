{
  "id": "aws-iam-role-cross-account-admin",
  "name": "IAM Role Cross Account Admin",
  "description": "IAM role can be assumed from external account and has administrator privileges",
  "effect": "forbid",
  "resource": "aws::iam::role",
  "conditions": [
    "assume_role_policy_document.Statement.Principal.AWS contains 'arn:aws:iam::'",
    "attached_policies contains 'AdministratorAccess'"
  ],
  "severity": "critical",
  "remediation": "Reduce permissions on cross-account roles or restrict trust to specific principals.",
  "tags": [
    "iam",
    "cross-account",
    "admin",
    "lateral-movement"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "IDENTITY_RISK",
    "LATERAL_MOVEMENT",
    "PRIVILEGE_ESCALATION"
  ],
