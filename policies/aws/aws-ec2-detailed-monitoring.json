{
  "id": "aws-ec2-detailed-monitoring-enabled",
  "name": "EC2 Detailed Monitoring Enabled",
  "description": "EC2 instances should have detailed monitoring enabled for better observability",
  "effect": "forbid",
  "resource": "aws::ec2::instance",
  "conditions": [
    "monitoring.state != 'enabled'"
  ],
  "severity": "low",
  "remediation": "Enable detailed monitoring on the EC2 instance for 1-minute CloudWatch metrics.",
  "tags": [
    "ec2",
    "monitoring",
    "observability"
  ],
  "risk_categories": [
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AU-2",
        "AU-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "10.2",
        "10.3"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC4",
        "CC7"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "8"
      ]
    }
  ]
}