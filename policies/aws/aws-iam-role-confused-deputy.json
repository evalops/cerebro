{
  "id": "aws-iam-role-confused-deputy-prevention",
  "name": "IAM Role Confused Deputy Prevention",
  "description": "IAM role trusted by AWS service should have ExternalId or SourceAccount condition",
  "effect": "forbid",
  "resource": "aws::iam::role",
  "conditions": [
    "assume_role_policy_document.Statement.Principal.Service != null",
    "assume_role_policy_document.Statement.Condition == null",
    "path not contains '/aws-service-role/'",
    "path not contains '/aws-reserved/sso.amazonaws.com/'"
  ],
  "severity": "medium",
  "remediation": "Add aws:SourceAccount or aws:SourceArn conditions to prevent confused deputy attacks.",
  "tags": [
    "iam",
    "trust-policy",
    "confused-deputy",
    "security"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "IDENTITY_RISK",
    "MISCONFIGURATION",
    "LATERAL_MOVEMENT"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "5",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Persistence",
      "technique": "T1098"
    },
    {
      "tactic": "Lateral Movement",
      "technique": "T1021"
    }
  ]
}