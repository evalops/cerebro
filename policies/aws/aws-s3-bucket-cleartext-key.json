{
  "id": "aws-s3-bucket-cleartext-key",
  "name": "S3 Bucket Contains Potential Credentials",
  "description": "S3 bucket objects contain potential secrets, API keys, or credentials based on filename patterns",
  "effect": "forbid",
  "resource": "aws::s3::object",
  "conditions": [
    "key MATCHES '.*\\.(pem|key|p12|pfx|credentials|env|secret)$' OR key MATCHES '.*(password|secret|api.?key|access.?key|private.?key).*'"
  ],
  "severity": "high",
  "remediation": "Move secrets to AWS Secrets Manager or Parameter Store. Remove credential files from S3. Enable versioning and audit access logs.",
  "tags": [
    "aws",
    "s3",
    "secrets",
    "data-exposure"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7",
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4",
        "3.5",
        "8.6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}