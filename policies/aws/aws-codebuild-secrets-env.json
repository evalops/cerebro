{
  "id": "aws-codebuild-secrets-in-env-vars",
  "name": "CodeBuild Secrets in Environment Variables",
  "description": "CodeBuild project has potential secrets stored in plaintext environment variables",
  "effect": "forbid",
  "resource": "aws::codebuild::project",
  "conditions": [
    "environment.environment_variables.name matches '(?i)(password|secret|api_key|token|credential)'",
    "environment.environment_variables.type == 'PLAINTEXT'"
  ],
  "severity": "high",
  "remediation": "Use PARAMETER_STORE or SECRETS_MANAGER type for sensitive environment variables.",
  "tags": [
    "secrets",
    "codebuild",
    "credentials",
    "cicd"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Execution",
      "technique": "T1059"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}