{
  "id": "aws-cloudwatch-alarm-missing",
  "name": "CloudTrail Without CloudWatch Alarm",
  "description": "CloudTrail trail does not have CloudWatch alarms configured for security events",
  "effect": "forbid",
  "resource": "aws::cloudtrail::trail",
  "conditions": [
    "cloud_watch_logs_log_group_arn != null",
    "associated_alarms_count == 0"
  ],
  "severity": "medium",
  "remediation": "Create CloudWatch metric filters and alarms for: unauthorized API calls, root login, IAM changes, VPC changes, S3 bucket policy changes. Reference CIS AWS Benchmark 4.x controls.",
  "tags": [
    "aws",
    "cloudwatch",
    "monitoring",
    "cis-aws-4.1"
  ],
  "frameworks": [
    {
      "name": "CIS AWS Foundations Benchmark v2.0",
      "controls": [
        "4.1"
      ]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AU-2",
        "AU-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "10.2",
        "10.3"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC4",
        "CC7"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "8"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Defense Evasion",
      "technique": "T1562"
    }
  ]
}