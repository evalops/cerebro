{
  "id": "ml-model-registry-no-versioning",
  "name": "ML Model Registry No Versioning",
  "description": "ML model registry does not enforce version control and audit trail",
  "effect": "forbid",
  "resource": "aws::sagemaker::model_package_group",
  "conditions": [
    "model_package_group_status != 'Pending' || model_package_group_status != 'Completed'",
    "model_approval_status == 'PendingManualApproval'"
  ],
  "severity": "medium",
  "remediation": "Implement model approval workflow and version control.",
  "tags": [
    "ai",
    "model-registry",
    "governance",
    "audit-trail"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AU-2",
        "AU-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "10.2",
        "10.3"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC4",
        "CC7"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "8"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Defense Evasion",
      "technique": "T1562"
    }
  ]
}