{
  "id": "github-repo-internal-exposed",
  "name": "GitHub Internal Repository Made Public",
  "description": "Repository appears to contain internal code but is publicly visible",
  "effect": "forbid",
  "resource": "github::repository",
  "conditions": [
    "visibility == 'public'",
    "name matches '(?i)(internal|private|confidential|secret)'"
  ],
  "severity": "critical",
  "remediation": "Change repository visibility to private or internal.",
  "tags": [
    "devsecops",
    "github",
    "data-exposure",
    "misconfiguration"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13"
      ]
    }
  ],
  "mitre_attack": [
