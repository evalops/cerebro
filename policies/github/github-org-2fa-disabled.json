{
  "id": "github-org-2fa-disabled",
  "name": "GitHub Organization 2FA Not Required",
  "description": "GitHub organization does not require two-factor authentication for all members",
  "effect": "forbid",
  "resource": "github::organization",
  "conditions": [
    "two_factor_requirement_enabled != true"
  ],
  "severity": "high",
  "remediation": "Enable 'Require two-factor authentication' in organization security settings. Members without 2FA will be removed from the organization.",
