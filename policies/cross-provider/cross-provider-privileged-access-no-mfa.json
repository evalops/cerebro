{
  "id": "cross-provider-privileged-access-no-mfa",
  "name": "Privileged Access Without MFA",
  "description": "User with administrative privileges in any cloud provider does not have MFA enabled",
  "effect": "forbid",
  "resource": "cross_provider::identity_cluster",
  "conditions": [
    "has_admin_role == true",
    "mfa_enabled_count == 0"
  ],
  "severity": "critical",
  "remediation": "Immediately enable MFA for all accounts with administrative access. Consider using hardware security keys for privileged accounts. Implement just-in-time access for admin roles.",
  "tags": [
    "cross-provider",
    "identity",
    "privileged-access",
    "mfa"
  ],
