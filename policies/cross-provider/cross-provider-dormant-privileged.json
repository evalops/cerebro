{
  "id": "cross-provider-dormant-privileged",
  "name": "Dormant Account with Privileged Access",
  "description": "User has not logged in for 90+ days but still has administrative access across providers",
  "effect": "forbid",
  "resource": "cross_provider::identity_cluster",
  "conditions": [
    "has_admin_role == true",
    "last_login_days_ago \u003e 90"
  ],
  "severity": "high",
  "remediation": "Review dormant privileged accounts. Remove admin access if no longer needed. Disable accounts for users who have left. Implement access certification reviews.",
