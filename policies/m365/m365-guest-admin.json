{
  "id": "m365-guest-admin",
  "name": "Microsoft 365 Guest User with Admin Role",
  "description": "External guest user has been assigned an administrative role in the tenant",
  "effect": "forbid",
  "resource": "m365::directory::user",
  "conditions": [
    "user_type == 'Guest'",
    "directory_roles ANY (is_privileged == true)"
  ],
  "severity": "critical",
  "remediation": "Remove admin roles from guest users immediately. Guest users should not have elevated privileges. Create internal accounts if external admin access is required.",
  "tags": [
    "m365",
    "identity",
    "privileged-access",
    "guest-user",
    "nist-ac-6"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "IDENTITY_RISK",
    "PRIVILEGE_ESCALATION"
  ],
  "frameworks": [
