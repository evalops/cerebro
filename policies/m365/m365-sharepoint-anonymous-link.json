{
  "id": "m365-sharepoint-anonymous-link",
  "name": "SharePoint Anonymous Sharing Link",
  "description": "SharePoint site allows anonymous sharing links that don't require authentication",
  "effect": "forbid",
  "resource": "m365::sharepoint::site",
  "conditions": [
    "sharing_capability IN ('ExternalUserAndGuestSharing', 'Anyone')",
    "anonymous_link_count \u003e 0"
  ],
  "severity": "high",
  "remediation": "Disable anonymous sharing links. Use authenticated links with expiration. Configure site-level and tenant-level sharing restrictions.",
  "tags": [
    "m365",
    "sharepoint",
    "data-exposure",
    "anonymous-access",
    "cwe-200"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA",
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7",
        "IA-2",
        "IA-5",
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4",
        "8.3",
        "8.4",
        "7.2"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13",
        "6",
        "5"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}