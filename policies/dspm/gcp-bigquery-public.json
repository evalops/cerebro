{
  "id": "gcp-bigquery-public-dataset",
  "name": "GCP BigQuery Public Dataset",
  "description": "BigQuery dataset is accessible by allUsers or allAuthenticatedUsers",
  "effect": "forbid",
  "resource": "gcp::bigquery::dataset",
  "conditions": [
    "access contains 'allUsers' || access contains 'allAuthenticatedUsers'"
  ],
  "severity": "critical",
  "remediation": "Remove allUsers and allAuthenticatedUsers from dataset IAM bindings.",
  "tags": [
    "dspm",
    "bigquery",
    "gcp",
    "data-exposure",
    "public-access"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA"
  ],
