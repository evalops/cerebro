{
  "id": "endpoint-edr-installed",
  "name": "EDR Agent Installed on Endpoints",
  "description": "Corporate endpoints should have an EDR (Endpoint Detection and Response) agent installed for threat detection and response",
  "effect": "forbid",
  "resource": "mdm_devices",
  "conditions": [
    "edr_agent_installed != true",
    "device_type == WORKSTATION"
  ],
  "severity": "critical",
  "remediation": "Install the EDR agent on the device through MDM deployment or manual installation",
  "remediation_steps": [
    "Identify devices without EDR agent",
    "Deploy EDR agent through MDM if supported",
    "For manual installation, contact device owner",
    "Verify agent registration in EDR console",
    "Confirm agent is actively reporting"
  ],
  "tags": [
    "endpoint",
    "edr",
    "antivirus",
    "malware-protection"
  ],
  "risk_categories": [
    "MISCONFIGURATION",
    "VULNERABILITY"
  ],
  "frameworks": [
    {
      "name": "CIS Controls v8",
      "controls": ["10.1", "10.2"]
    },
    {
      "name": "SOC 2",
      "controls": ["CC6.8"]
    },
    {
      "name": "ISO 27001:2022",
      "controls": ["A.8.7"]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": ["SI-3"]
    },
    {
      "name": "HIPAA",
      "controls": ["164.308(a)(5)(ii)(B)"]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Defense Evasion",
      "technique": "T1562.001"
    }
  ]
}
