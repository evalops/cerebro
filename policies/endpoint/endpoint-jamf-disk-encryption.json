{
  "id": "endpoint-jamf-disk-encryption",
  "name": "Jamf Devices Without Disk Encryption",
  "description": "Identifies Jamf-managed macOS computers without FileVault disk encryption enabled",
  "severity": "HIGH",
  "category": "endpoint",
  "resource_type": "jamf_computer",
  "frameworks": [
    {
      "name": "CIS Controls v8",
      "controls": [
        "3.6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6.7"
      ]
    },
    {
      "name": "ISO 27001:2022",
      "controls": [
        "A.8.24"
      ]
    },
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "SC-28"
      ]
    },
    {
      "name": "HIPAA",
      "controls": [
        "164.312(a)(2)(iv)"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5.1"
      ]
    }
  ],
  "enabled": true,
  "query": "SELECT id, name, user_email, os_version FROM jamf_computers WHERE COALESCE(filevault_enabled, false) = false",
  "remediation": "Enable FileVault via Jamf policies and ensure recovery keys are escrowed securely.",
  "tags": [
    "endpoint",
    "jamf",
    "encryption",
    "disk-encryption",
    "filevault"
  ]
}
