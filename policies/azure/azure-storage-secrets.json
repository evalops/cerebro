{
  "id": "azure-storage-secrets-artifact",
  "name": "Azure Storage Contains Credential Artifacts",
  "description": "Azure Storage blob contains potential credentials, private keys, or sensitive configuration files",
  "effect": "forbid",
  "resource": "azure::storage::blob",
  "conditions": [
    "name MATCHES '(?i).*\\.(pem|key|pfx|p12|env|credentials|secret|htpasswd)$'",
    "name MATCHES '(?i).*(password|secret|api.?key|private.?key|connection.?string).*'"
  ],
  "severity": "high",
  "remediation": "Move secrets to Azure Key Vault. Remove credential files from blob storage. Enable soft delete for recovery. Audit access logs for potential exposure.",
  "tags": [
    "azure",
    "storage",
    "secrets",
    "data-exposure",
    "cwe-312"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7",
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4",
        "3.5",
        "8.6"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}