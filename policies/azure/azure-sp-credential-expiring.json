{
  "id": "azure-sp-credential-expiring",
  "name": "Azure Service Principal Credential Expiring",
  "description": "Azure service principal has credentials expiring within 30 days",
  "effect": "forbid",
  "resource": "azure::ad::service_principal",
  "conditions": [
    "password_credentials.end_date_time_days \u003c 30"
  ],
  "severity": "medium",
  "remediation": "Rotate service principal credentials before expiration to prevent service disruption.",
  "tags": [
    "azure-ad",
    "service-principal",
    "credentials",
    "rotation"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1078"
    },
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    }
  ]
}