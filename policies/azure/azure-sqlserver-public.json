{
  "id": "azure-sqlserver-public",
  "name": "Azure SQL Server Allows All Azure IPs",
  "description": "Azure SQL Server firewall allows connections from all Azure services (0.0.0.0)",
  "effect": "forbid",
  "resource": "azure::sql::server",
  "conditions": [
    "firewall_rules ANY (start_ip_address == '0.0.0.0' AND end_ip_address == '0.0.0.0')"
  ],
  "severity": "high",
  "remediation": "Remove the 'Allow Azure services' firewall rule. Use Private Endpoints for secure access. Add specific IP ranges for required services.",
