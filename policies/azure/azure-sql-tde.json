{
  "id": "azure-sql-transparent-data-encryption",
  "name": "Azure SQL Transparent Data Encryption",
  "description": "Azure SQL databases should have Transparent Data Encryption enabled",
  "effect": "forbid",
  "resource": "azure::sql::database",
  "conditions": [
    "transparent_data_encryption.status != 'Enabled'"
  ],
  "severity": "high",
  "remediation": "Enable Transparent Data Encryption on the database.",
