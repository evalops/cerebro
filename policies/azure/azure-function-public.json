{
  "id": "azure-function-public",
  "name": "Azure Function App Publicly Accessible",
  "description": "Azure Function App allows anonymous access without authentication",
  "effect": "forbid",
  "resource": "azure::functionapp::function",
  "conditions": [
    "auth_level == 'anonymous'",
    "site_config.http20_enabled == true OR http_trigger == true"
  ],
  "severity": "medium",
  "remediation": "Configure authentication for the Function App. Use function keys or Azure AD authentication. Restrict network access using Private Endpoints or IP restrictions.",
  "tags": [
    "azure",
    "functions",
    "serverless",
    "authentication"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-2",
        "IA-5",
        "AC-2",
        "AC-6"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "8.3",
        "8.4",
        "7.2"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "6",
        "5"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Execution",
      "technique": "T1059"
    }
  ]
}