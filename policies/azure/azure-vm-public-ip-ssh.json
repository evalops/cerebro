{
  "id": "azure-vm-public-ip-ssh",
  "name": "Azure VM Public IP with SSH Exposed",
  "description": "Azure VM has public IP with SSH port 22 allowed from Any source in NSG",
  "effect": "forbid",
  "resource": "azure::compute::virtual_machine",
  "conditions": [
    "public_ip_address != null",
    "network_security_group.rules.destination_port == '22'",
    "network_security_group.rules.source_address_prefix == '*'",
    "network_security_group.rules.access == 'Allow'"
  ],
  "severity": "critical",
  "remediation": "Remove public IP or restrict NSG rules to specific IP ranges. Use Azure Bastion for secure access.",
  "tags": [
    "cis-azure-6.1",
    "exposure",
    "vm",
    "network",
    "ssh"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
