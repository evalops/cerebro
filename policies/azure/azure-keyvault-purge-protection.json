{
  "id": "azure-keyvault-purge-protection",
  "name": "Azure Key Vault Purge Protection",
  "description": "Azure Key Vaults should have purge protection enabled",
  "effect": "forbid",
  "resource": "azure::keyvault::vault",
  "conditions": [
    "properties.enable_purge_protection != true"
  ],
  "severity": "medium",
  "remediation": "Enable purge protection on the Key Vault to prevent permanent deletion.",
  "tags": [
    "cis-azure-8.5",
    "keyvault",
    "data-protection"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-5",
        "SC-12"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "8.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Credential Access",
      "technique": "T1552"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}