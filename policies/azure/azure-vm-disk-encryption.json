{
  "id": "azure-vm-disk-encryption",
  "name": "Azure VM Disk Encryption",
  "description": "Azure VMs should have disk encryption enabled",
  "effect": "forbid",
  "resource": "azure::compute::virtual_machine",
  "conditions": [
    "storage_profile.os_disk.encryption_settings.enabled != true"
  ],
  "severity": "high",
  "remediation": "Enable Azure Disk Encryption using BitLocker (Windows) or DM-Crypt (Linux).",
  "tags": [
    "cis-azure-7.2",
    "compute",
    "encryption",
    "disk"
  ],
  "risk_categories": [
    "UNPROTECTED_DATA",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "SC-12",
        "SC-13",
        "SC-28"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "3.5",
        "4.2"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "3"
      ]
    }
  ]
}