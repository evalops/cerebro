{
  "id": "k8s-ingress-public",
  "name": "Kubernetes Ingress Exposes Sensitive Service",
  "description": "Ingress resource exposes a service to the internet without authentication or with sensitive paths",
  "effect": "forbid",
  "resource": "k8s::networking::ingress",
  "conditions": [
    "spec.rules ANY (http.paths ANY (path MATCHES '/admin|/api/internal|/debug|/metrics|/health' AND backend.service.name != null))",
    "metadata.annotations['nginx.ingress.kubernetes.io/auth-type'] == null"
  ],
  "severity": "high",
  "remediation": "Add authentication annotations to the Ingress. Use network policies to restrict access. Consider using a service mesh for mTLS.",
  "tags": [
    "kubernetes",
    "ingress",
    "network-exposure",
    "authentication"
  ],
  "risk_categories": [
    "EXTERNAL_EXPOSURE",
    "UNPROTECTED_DATA",
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "AC-3",
        "SC-7",
        "IA-2",
        "IA-5"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "1.3",
        "1.4",
        "8.3",
        "8.4"
      ]
    },
    {
      "name": "SOC 2",
      "controls": [
        "CC6"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "12",
        "13",
        "6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Initial Access",
      "technique": "T1190"
    },
    {
      "tactic": "Collection",
      "technique": "T1530"
    }
  ]
}