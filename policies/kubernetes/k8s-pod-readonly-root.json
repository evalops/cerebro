{
  "id": "k8s-pod-readonly-root-filesystem",
  "name": "K8s Pod Read-Only Root Filesystem",
  "description": "Containers should use read-only root filesystem",
  "effect": "forbid",
  "resource": "kubernetes::pod",
  "conditions": [
    "spec.containers.security_context.read_only_root_filesystem != true"
  ],
  "severity": "medium",
  "remediation": "Set readOnlyRootFilesystem: true in container security context.",
  "tags": [
    "cis-k8s-5.2.4",
    "pod-security",
    "filesystem"
  ],
  "risk_categories": [
    "IDENTITY_RISK",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "CIS Kubernetes Benchmark",
      "controls": [
        "5.2.4"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Privilege Escalation",
      "technique": "T1078"
    }
  ]
}