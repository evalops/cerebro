{
  "id": "k8s-pod-no-host-network",
  "name": "K8s Pod No Host Network",
  "description": "Pods should not use host network namespace",
  "effect": "forbid",
  "resource": "kubernetes::pod",
  "conditions": [
    "spec.host_network == true"
  ],
  "severity": "high",
  "remediation": "Remove hostNetwork: true from pod spec.",
  "tags": [
    "cis-k8s-5.2.4",
    "pod-security",
    "network"
  ],
  "risk_categories": [
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "CIS Kubernetes Benchmark",
      "controls": [
        "5.2.4"
      ]
    }
  ]
}