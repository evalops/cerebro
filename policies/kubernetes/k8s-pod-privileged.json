{
  "id": "k8s-pod-no-privileged",
  "name": "K8s Pod No Privileged Containers",
  "description": "Pods should not run privileged containers",
  "effect": "forbid",
  "resource": "kubernetes::pod",
  "conditions": [
    "spec.containers.security_context.privileged == true"
  ],
  "severity": "critical",
  "remediation": "Remove privileged: true from container security context.",
  "tags": [
    "cis-k8s-5.2.1",
    "pod-security",
    "privileged"
  ],
  "risk_categories": [
    "IDENTITY_RISK",
    "MISCONFIGURATION",
    "PRIVILEGE_ESCALATION"
  ],
