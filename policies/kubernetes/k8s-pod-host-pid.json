{
  "id": "k8s-pod-no-host-pid",
  "name": "K8s Pod No Host PID",
  "description": "Pods should not share host PID namespace",
  "effect": "forbid",
  "resource": "kubernetes::pod",
  "conditions": [
    "spec.host_pid == true"
  ],
  "severity": "high",
  "remediation": "Remove hostPID: true from pod spec.",
  "tags": [
    "cis-k8s-5.2.2",
    "pod-security",
    "namespace"
  ],
  "risk_categories": [
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "CIS Kubernetes Benchmark",
      "controls": [
        "5.2.2"
      ]
    }
  ]
}