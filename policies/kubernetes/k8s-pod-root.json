{
  "id": "k8s-pod-no-run-as-root",
  "name": "K8s Pod No Run As Root",
  "description": "Pods should not run containers as root user",
  "effect": "forbid",
  "resource": "kubernetes::pod",
  "conditions": [
    "spec.security_context.run_as_non_root != true",
    "spec.containers.security_context.run_as_user == 0"
  ],
  "severity": "high",
  "remediation": "Set runAsNonRoot: true and specify a non-zero runAsUser.",
  "tags": [
    "cis-k8s-5.2.6",
    "pod-security",
    "root"
  ],
  "risk_categories": [
    "IDENTITY_RISK",
    "MISCONFIGURATION"
  ],
  "frameworks": [
    {
      "name": "CIS Kubernetes Benchmark",
      "controls": [
        "5.2.6"
      ]
    }
  ],
  "mitre_attack": [
    {
      "tactic": "Persistence",
      "technique": "T1098"
    },
    {
      "tactic": "Privilege Escalation",
      "technique": "T1078"
    }
  ]
}