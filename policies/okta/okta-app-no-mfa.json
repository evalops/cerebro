{
  "id": "okta-app-no-mfa",
  "name": "Okta Application Without MFA Policy",
  "description": "Okta application does not have an authentication policy requiring MFA",
  "effect": "forbid",
  "resource": "okta::application",
  "conditions": [
    "sign_on_policy.rules NOT ANY (actions.signon.factor_mode == 'MFA_REQUIRED')",
    "label NOT MATCHES '.*(test|dev|sandbox).*'"
  ],
  "severity": "high",
  "remediation": "Create or update the application's sign-on policy to require MFA. Use Okta's authentication policies to enforce MFA for sensitive applications.",
  "tags": [
    "okta",
    "application",
    "mfa",
    "authentication"
  ],
  "risk_categories": [
    "IDENTITY_RISK"
  ],
  "frameworks": [
    {
      "name": "NIST 800-53 r5",
      "controls": [
        "IA-2",
        "IA-5"
      ]
    },
    {
      "name": "PCI DSS v4.0.1",
      "controls": [
        "8.3",
        "8.4"
      ]
    },
    {
      "name": "CIS Controls v8",
      "controls": [
        "6"
      ]
    }
  ]
}