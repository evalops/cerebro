{
  "id": "okta-password-policy-weak",
  "name": "Okta Password Policy Does Not Meet Standards",
  "description": "Okta password policy does not enforce sufficient complexity requirements",
  "effect": "forbid",
  "resource": "okta::policy::password",
  "conditions": [
    "settings.password.complexity.min_length \u003c 12 OR settings.password.age.max_age_days \u003e 365 OR settings.password.lockout.max_attempts \u003e 10"
  ],
  "severity": "medium",
  "remediation": "Update password policy: minimum 12 characters, lockout after 5-10 attempts, reasonable password age. Consider passwordless authentication with WebAuthn.",
  "tags": [
    "okta",
    "authentication",
    "password-policy",
    "cis"
  ],
  "risk_categories": [
    "IDENTITY_RISK"
  ],
